---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CopyLLMsButton from "@/components/CopyLLMsButton";
import agentsMarkdown from "@bruhs/theme/AGENTS.md?raw";
import { marked } from "marked";

marked.setOptions({ gfm: true, breaks: false });
const html = await marked.parse(agentsMarkdown);

const rawUrl = "/llms.txt";
---

<BaseLayout>
  <div class="p-6 md:p-8 flex flex-col gap-12 md:gap-16">
    <section>
      <h1 class="text-display-sm font-semibold tracking-tight mb-2 text-balance">Agents</h1>
      <p class="text-body-lg text-rambutan-400 max-w-[65ch] text-pretty mb-6">
        Point your coding agent at this page. It covers adoption paths, the full
        vocabulary, every component pattern, and the hard bans — enough for any
        agent to implement Bruhs in a fresh project without asking clarifying questions.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <CopyLLMsButton client:visible content={agentsMarkdown} />
        <a
          href={rawUrl}
          class="inline-flex items-center gap-1.5 rounded-grape bg-transparent py-2 pr-3 pl-3 text-button text-rambutan-100 inset-ring inset-ring-rambutan-100/15 hover:bg-longan-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-persimmon-400 transition"
        >
          View raw /llms.txt
          <svg viewBox="0 0 16 16" fill="currentColor" class="size-4 shrink-0">
            <path d="M6.5 3.5a.75.75 0 0 1 .75-.75h5a.75.75 0 0 1 .75.75v5a.75.75 0 0 1-1.5 0V5.31L3.78 12.78a.75.75 0 1 1-1.06-1.06L10.19 4.25H7.25a.75.75 0 0 1-.75-.75Z" />
          </svg>
        </a>
      </div>
    </section>

    <section class="bruhs-md rounded-lychee bg-longan-900 p-6 md:p-10 inset-ring inset-ring-white/5">
      <article set:html={html} />
    </section>
  </div>
</BaseLayout>

<style is:global>
  /* Bruhs-styled rendering of the AGENTS.md markdown. Selectors are scoped
   * to .bruhs-md so no other prose on the site inherits these rules. */

  .bruhs-md {
    --bruhs-md-gap: 1.25rem;
  }

  .bruhs-md article > * + * {
    margin-top: var(--bruhs-md-gap);
  }

  .bruhs-md h1 {
    font-size: clamp(2rem, 3.2vw + 0.8rem, 3.5rem);
    line-height: 1.1;
    font-weight: 400;
    letter-spacing: -0.02em;
    font-family: var(--font-krypton), ui-monospace, Menlo, monospace;
    text-wrap: balance;
    margin-top: 2rem;
  }

  .bruhs-md h2 {
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: -0.005em;
    font-family: var(--font-xenon), ui-monospace, Menlo, monospace;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rambutan-100);
    border-top-color: color-mix(in oklch, var(--color-rambutan-100) 10%, transparent);
  }

  .bruhs-md article > h2:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .bruhs-md h3 {
    font-size: 1.25rem;
    line-height: 1.3;
    font-weight: 500;
    font-family: var(--font-xenon), ui-monospace, Menlo, monospace;
    margin-top: 1.75rem;
  }

  .bruhs-md h4 {
    font-size: 1.125rem;
    line-height: 1.4;
    font-weight: 500;
    font-family: var(--font-xenon), ui-monospace, Menlo, monospace;
    margin-top: 1.5rem;
  }

  .bruhs-md p,
  .bruhs-md li {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-rambutan-300);
    font-family: var(--font-neon), ui-monospace, Menlo, monospace;
    text-wrap: pretty;
  }

  .bruhs-md p {
    max-width: 72ch;
  }

  .bruhs-md strong {
    color: var(--color-rambutan-100);
    font-weight: 600;
  }

  .bruhs-md a {
    color: var(--color-persimmon-300);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklch, var(--color-persimmon-400) 30%, transparent);
    text-underline-offset: 3px;
  }

  .bruhs-md a:hover {
    color: var(--color-persimmon-200);
    text-decoration-color: color-mix(in oklch, var(--color-persimmon-400) 60%, transparent);
  }

  .bruhs-md ul,
  .bruhs-md ol {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 72ch;
  }

  .bruhs-md ul {
    list-style: disc;
  }

  .bruhs-md ol {
    list-style: decimal;
  }

  .bruhs-md li::marker {
    color: var(--color-rambutan-500);
  }

  .bruhs-md code {
    font-size: 0.875rem;
    font-family: var(--font-neon), ui-monospace, Menlo, monospace;
    color: var(--color-persimmon-200);
    background: color-mix(in oklch, var(--color-persimmon-500) 12%, transparent);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-seed);
  }

  .bruhs-md pre {
    background: var(--color-longan-950);
    border-radius: var(--radius-grape);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    box-shadow: inset 0 0 0 1px color-mix(in oklch, white 5%, transparent);
    max-width: none;
  }

  .bruhs-md pre code {
    color: var(--color-rambutan-100);
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .bruhs-md blockquote {
    border-left: 2px solid var(--color-persimmon-500);
    padding-left: 1rem;
    color: var(--color-rambutan-300);
    font-family: var(--font-radon), ui-monospace, Menlo, monospace;
  }

  .bruhs-md hr {
    border: 0;
    border-top: 1px solid color-mix(in oklch, var(--color-rambutan-100) 10%, transparent);
    margin-block: 2rem;
  }

  .bruhs-md table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-neon), ui-monospace, Menlo, monospace;
    font-size: 0.875rem;
    display: block;
    overflow-x: auto;
  }

  .bruhs-md thead {
    text-align: left;
  }

  .bruhs-md th {
    color: var(--color-rambutan-100);
    font-weight: 500;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid color-mix(in oklch, var(--color-rambutan-100) 15%, transparent);
    white-space: nowrap;
  }

  .bruhs-md td {
    color: var(--color-rambutan-300);
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid color-mix(in oklch, var(--color-rambutan-100) 5%, transparent);
    vertical-align: top;
  }

  .bruhs-md tbody tr:last-child td {
    border-bottom: 0;
  }

  .bruhs-md em {
    font-style: italic;
    color: var(--color-rambutan-200);
  }
</style>
